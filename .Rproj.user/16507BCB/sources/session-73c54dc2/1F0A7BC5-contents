### 3. Score Information by District {data-width=500}

```{r score-map}
# ── District-level score_A summary ──────────────────────────────────────────
dist_score <- df_plot %>%
  mutate(district = as.character(district)) %>%
  filter(!is.na(district), !is.na(score_A)) %>%
  group_by(district) %>%
  summarise(
    n      = n(),
    avg    = round(mean(score_A,              na.rm = TRUE), 2),
    median = round(median(score_A,            na.rm = TRUE), 2),
    q1     = round(quantile(score_A, 0.25,    na.rm = TRUE), 2),
    q3     = round(quantile(score_A, 0.75,    na.rm = TRUE), 2),
    .groups = "drop"
  )

# Known district centroids (Siraha, Saptari, Udaypur — eastern Nepal)
district_coords <- tibble::tribble(
  ~district,   ~lat,    ~lng,
  "Siraha",    26.65,   86.21,
  "Saptari",   26.63,   86.72,
  "Udaypur",   26.95,   86.53
)

map_score <- dist_score %>%
  left_join(district_coords, by = "district") %>%
  filter(!is.na(lat))

pal_score <- colorNumeric(
  palette = c("#AED6F1", "#1B4F72"),
  domain  = range(map_score$avg, na.rm = TRUE)
)

popup_score <- paste0(
  "<b style='font-size:14px;'>", map_score$district, "</b><br>",
  "<hr style='margin:4px 0;'>",
  "<b>n</b> = ", map_score$n, "<br>",
  "<b>Mean&nbsp;&nbsp;&nbsp;</b>: ", map_score$avg,    "<br>",
  "<b>Median</b>: ", map_score$median, "<br>",
  "<b>Q1&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</b>: ", map_score$q1, "<br>",
  "<b>Q3&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</b>: ", map_score$q3
)

leaflet(map_score) %>%
  addProviderTiles(providers$CartoDB.Positron) %>%
  setView(lng = 86.5, lat = 26.8, zoom = 9) %>%
  addCircleMarkers(
    lng         = ~lng,
    lat         = ~lat,
    radius      = ~scales::rescale(n, to = c(14, 30)),
    fillColor   = ~pal_score(avg),
    color       = "#1B4F72",
    fillOpacity = 0.85,
    weight      = 2,
    popup       = popup_score,
    label       = ~paste0(district, " (click for details)"),
    labelOptions = labelOptions(
      noHide    = TRUE,
      direction = "top",
      style     = list("font-weight" = "bold", "font-size" = "12px",
                       "background"  = "rgba(255,255,255,0.8)",
                       "border"      = "1px solid #ccc",
                       "padding"     = "3px 6px")
    )
  ) %>%
  addLegend(
