    /* Core toggle function — used by both triggers */
    function toggleAbout() {
      var el    = document.getElementById("about-overlay");
      var arrow = document.getElementById("about-arrow");
      if (!el) return;
      var opening = (el.style.display === "none" || el.style.display === "");
      el.style.display        = opening ? "flex" : "none";
      document.body.style.overflow = opening ? "hidden" : "";
      if (arrow) arrow.innerHTML  = opening ? "&#x25B2;" : "&#x25BC;";
    }

    /* Hook navbar link — runs repeatedly via MutationObserver until found */
    function hookNavbarLink() {
      var links = document.querySelectorAll(".navbar-nav a, .navbar a");
      var hooked = false;
      links.forEach(function(link) {
        if (link.textContent.indexOf("About") !== -1 && !link.dataset.hooked) {
          link.dataset.hooked = "1";
          link.setAttribute("href", "javascript:void(0)");
          link.addEventListener("click", function(e) {
            e.preventDefault();
            e.stopPropagation();
            toggleAbout();
          });
          hooked = true;
        }
      });
      return hooked;
    }

    /* Try immediately, then watch DOM for navbar to appear */
    if (!hookNavbarLink()) {
      var observer = new MutationObserver(function(mutations, obs) {
        if (hookNavbarLink()) obs.disconnect();
      });
      observer.observe(document.body, { childList: true, subtree: true });
    }

    /* Also retry on DOMContentLoaded and window load as fallbacks */
    document.addEventListener("DOMContentLoaded", hookNavbarLink);
    window.addEventListener("load", hookNavbarLink);

    /* Close on Escape */
    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape") {
        var el = document.getElementById("about-overlay");
        if (el && el.style.display === "flex") toggleAbout();
      }
    });
  '))

