land_df <- df_plot %>%
  filter(!is.na(occup_4cat), !is.na(land_own)) %>%
  count(occup_4cat, land_own) %>%
  group_by(occup_4cat) %>%
  mutate(prop = n / sum(n)) %>%
  ungroup() %>%
  mutate(occup_4cat = as.character(occup_4cat),
