```{r cleaning, include=FALSE}
df_nepal <- read_dta(here::here("data", "nepal_clean_final.dta"))

df_plot <- df_nepal %>%
  mutate(
    score_A_tert = as_factor(score_A_tert),
    land_own     = as_factor(land_own),
    occup_4cat   = as_factor(occup_4cat),
    score_A      = as.numeric(score_A),
    mddw         = as.numeric(mddw),
    a7_freq      = as.numeric(a7_freq),
    a9_daily     = as.numeric(a9_daily),
    emp_foodprod = as.numeric(emp_foodprod),
    district     = as_factor(district)
  ) %>%
  mutate(
    score_A_tert = case_when(
      score_A_tert %in% c("1", "Low",    "low",    "LOW")                  ~ "Low",
      score_A_tert %in% c("2", "Medium", "Med",    "med", "medium", "MED") ~ "Med",
      score_A_tert %in% c("3", "High",   "high",   "HIGH")                 ~ "High",
      TRUE ~ as.character(score_A_tert)
    ),
    score_A_tert = factor(score_A_tert, levels = c("Low", "Med", "High")),
    land_own = case_when(
      land_own %in% c("1", "Yes", "yes", "Y") ~ "Yes",
      land_own %in% c("0", "No",  "no",  "N") ~ "No",
      TRUE ~ as.character(land_own)
    ),
    # A7+A9 combined: frequent plant-based AND frequent animal-sourced
    a7a9_both = as.numeric(a7_freq == 1 & a9_daily == 1)
  )
