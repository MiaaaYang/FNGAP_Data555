occ_json     <- jsonlite::toJSON(occ_levels, auto_unbox = FALSE)
no_cnt_json  <- jsonlite::toJSON(no_counts)
yes_cnt_json <- jsonlite::toJSON(yes_counts)
no_pct_json  <- jsonlite::toJSON(no_props)
yes_pct_json <- jsonlite::toJSON(yes_props)

checkbox_ui <- tags$div(
  style = "font-size:13px; padding: 4px 0 6px 0;",
  tags$strong("Select Occupations:"),
  tags$div(
    id    = "occ-checkboxes",
    style = "display:flex; flex-wrap:wrap; gap:5px 16px; margin-top:5px;",
    lapply(occ_levels, function(occ) {
      tags$label(
        style = "cursor:pointer; user-select:none;",
        tags$input(type = "checkbox", value = occ, checked = NA,
                   onchange = "filterLandOcc()"),
        paste0(" ", occ)
      )
    })
  )
)

js_code <- tags$script(HTML(paste0('
var _OCC  = ', occ_json, ';
var _NOCN = ', no_cnt_json,  '; var _YECN = ', yes_cnt_json, ';
var _NOPC = ', no_pct_json,  '; var _YEPC = ', yes_pct_json, ';

function filterLandOcc() {
  var boxes    = document.querySelectorAll("#occ-checkboxes input");
  var selected = Array.from(boxes).filter(b => b.checked).map(b => b.value);
  var idx      = _OCC.map((o,i) => selected.includes(o) ? i : -1).filter(i => i >= 0);
  var xV   = idx.map(i => _OCC[i]);
  var noCn = idx.map(i => _NOCN[i]); var yeCn = idx.map(i => _YECN[i]);
  var noPc = idx.map(i => _NOPC[i]); var yePc = idx.map(i => _YEPC[i]);
  var plots = document.querySelectorAll(".js-plotly-plot");
  var gd    = plots[plots.length - 1];
  if (!gd) return;
  var isPercent = gd.layout && gd.layout.yaxis &&
                  (gd.layout.yaxis.title === "Percent" ||
                   (gd.layout.yaxis.title && gd.layout.yaxis.title.text === "Percent"));
  var noY = isPercent ? noPc : noCn;
  var yeY = isPercent ? yePc : yeCn;
  var pctFmt = function(v) { return (v * 100).toFixed(1) + "%"; };
  var noTxt = xV.map((o,j) => "Occupation: "+o+"<br>Land: No<br>"+
    (isPercent ? "Percent: "+pctFmt(noY[j]) : "Count: "+noY[j]));
  var yeTxt = xV.map((o,j) => "Occupation: "+o+"<br>Land: Yes<br>"+
    (isPercent ? "Percent: "+pctFmt(yeY[j]) : "Count: "+yeY[j]));
  Plotly.restyle(gd, {x:[xV], y:[noY], text:[noTxt]}, [0]);
  Plotly.restyle(gd, {x:[xV], y:[yeY], text:[yeTxt]}, [1]);
}
')))

tagList(checkbox_ui, p_land, js_code)
