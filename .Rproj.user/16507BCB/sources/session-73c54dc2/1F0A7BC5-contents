})

# ── Count / Percent toggle (second row) ─────────────────────────────────────
# We need y and text for ALL 8 traces for each mode
cnt_y <- unlist(lapply(all_dats, function(d) list(d$n_pos, d$n_neg)),
                recursive = FALSE)
pct_y <- unlist(lapply(all_dats, function(d) list(d$p_pos, d$p_neg)),
                recursive = FALSE)

cnt_txt <- unlist(lapply(seq_along(outcomes), function(i) {
  d <- all_dats[[i]]
