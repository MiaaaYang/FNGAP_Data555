### 2. Score Distribution by Outcome {data-width=420}

```{r diet-outcome-plot}
# ── Layout: x = Score A Tertile (Low/Med/High)
#            grouped bars = E- (0) and E+ (1) for the selected outcome
#            Outcome selector: 4 buttons (MDDW, A7, A9, A7+A9)
#            Count / Percent toggle
# ── Total traces = 8  (E- and E+ for each of the 4 outcomes)

tert_levels <- c("Low", "Med", "High")

# Helper: counts & proportions of 0/1 by tertile for one binary variable
make_freq <- function(var) {
  df_plot %>%
    filter(!is.na(score_A_tert), !is.na(!!sym(var))) %>%
    mutate(score_A_tert = factor(as.character(score_A_tert),
                                 levels = tert_levels)) %>%
    group_by(score_A_tert) %>%
    summarise(
      n_pos = sum(!!sym(var) == 1, na.rm = TRUE),
      n_neg = sum(!!sym(var) == 0, na.rm = TRUE),
      tot   = n(),
      .groups = "drop"
    ) %>%
    mutate(p_pos = n_pos / tot,
           p_neg = n_neg / tot) %>%
    arrange(score_A_tert)
}

# 4 outcomes: variable name, display label, colours for E+ and E-
outcomes <- list(
  list(var = "mddw",      label = "MDDW",
       col_pos = "#5C8DBF", col_neg = "#B0C9E8"),
  list(var = "a7_freq",   label = "A7 (Plant-Based Food)",
       col_pos = "#4CAF50", col_neg = "#C8E6C9"),
  list(var = "a9_daily",  label = "A9 (Animal-Sourced Food)",
       col_pos = "#EF5350", col_neg = "#FFCDD2"),
  list(var = "a7a9_both", label = "A7+A9 (Plant & Animal)",
       col_pos = "#FFA726", col_neg = "#FFE0B2")
)

# Pre-compute data for all 4 outcomes
all_dats <- lapply(outcomes, function(oc) make_freq(oc$var))

# ── Build plot: 8 traces, only outcome-1 visible at start ──────────────────
p_diet <- plot_ly()

for (i in seq_along(outcomes)) {
  oc  <- outcomes[[i]]
  d   <- all_dats[[i]]
  vis <- (i == 1)

  # E+ trace  (binary = 1)
  p_diet <- p_diet %>%
    add_trace(
      x         = d$score_A_tert,
      y         = d$n_pos,
      type      = "bar",
      name      = "E+",
      legendgroup = "eplus",
      showlegend  = (i == 1),
      marker    = list(color = oc$col_pos,
                       line  = list(color = "black", width = 1)),
      text      = paste0("E+  |  Tertile: ", d$score_A_tert,
                         "<br>Count: ", d$n_pos,
                         "  (", round(d$p_pos * 100, 1), "%)"),
      hoverinfo = "text",
      visible   = vis
    )

  # E- trace  (binary = 0)
  p_diet <- p_diet %>%
    add_trace(
      x         = d$score_A_tert,
      y         = d$n_neg,
      type      = "bar",
      name      = "E-",
      legendgroup = "eminus",
      showlegend  = (i == 1),
      marker    = list(color = oc$col_neg,
                       line  = list(color = "black", width = 1)),
      text      = paste0("E-  |  Tertile: ", d$score_A_tert,
                         "<br>Count: ", d$n_neg,
                         "  (", round(d$p_neg * 100, 1), "%)"),
      hoverinfo = "text",
      visible   = vis
    )
}

# ── Visibility helper: show only the 2 traces for outcome i ────────────────
n_out    <- length(outcomes)   # 4
n_traces <- n_out * 2          # 8

make_vis <- function(active_i) {
  v <- rep(FALSE, n_traces)
  v[c(active_i * 2 - 1, active_i * 2)] <- TRUE
  as.list(v)
}

# ── Outcome-selector buttons (top row) ─────────────────────────────────────
outcome_btns <- lapply(seq_along(outcomes), function(i) {
